# Copy this file to terraform.tfvars and fill in your values.
# Do NOT commit terraform.tfvars to version control.

instance_name         = "satisfactory-server"
image_id              = "1dbf558b-5b83-4ae4-9039-73670564b17f"
flavor_name           = "c4.xlarge"               # 4 vCPU / 16 GB — rename as needed
key_pair_name         = "my-keypair"
subnet_cidr           = "10.10.10.0/24"      # private subnet Terraform will create
external_network_name = "public"              # name of your cloud's external/floating-IP pool
ssh_allowed_cidr      = "0.0.0.0/0"              # restrict to your IP, e.g. "203.0.113.5/32"
steam_anonymous       = true
sf_server_name        = "Satisfactory Server"
# Sensitive vars (sf_admin_password, r2_*) are set via .env → TF_VAR_* — do not put them here
