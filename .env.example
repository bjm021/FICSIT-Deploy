# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# Satisfactory server
SF_ADMIN_PASSWORD=changeme_use_a_strong_password

# Cloudflare R2 backup storage
# Account ID: Cloudflare dashboard → R2 → Overview (right sidebar)
# API token:  Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=satisfactory-backups
R2_JURISDICTION=    # leave empty for standard, set to "eu" for EU-jurisdiction buckets

# GitLab remote state backend
# Token:  GitLab project → Settings → Access Tokens (role: Maintainer, scope: api)
GITLAB_PROJECT_URL=https://gitlab.example.com/user/repo
GITLAB_PROJECT_ACCESS_TOKEN=
TF_STATE_NAME=satisfactory

# OpenStack credentials
OS_AUTH_URL=https://your-cloud:13000
OS_AUTH_TYPE=v3applicationcredential
OS_APPLICATION_CREDENTIAL_ID=
OS_APPLICATION_CREDENTIAL_SECRET=
OS_REGION_NAME=eu-central
OS_INTERFACE=public
OS_IDENTITY_API_VERSION=3
